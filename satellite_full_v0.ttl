#################################################################
#    Rules
#################################################################

satellite:v rdf:type swrl:Variable .

satellite:c rdf:type swrl:Variable .

satellite:x rdf:type swrl:Variable .

satellite:f rdf:type swrl:Variable .

satellite:lowSev rdf:type swrl:Variable .

satellite:mediumSev rdf:type swrl:Variable .

satellite:s rdf:type swrl:Variable .

satellite:f2 rdf:type swrl:Variable .

satellite:y rdf:type swrl:Variable .

satellite:solar rdf:type swrl:Variable .

satellite:battery rdf:type swrl:Variable .

satellite:y3 rdf:type swrl:Variable .

satellite:x3 rdf:type swrl:Variable .

satellite:f3 rdf:type swrl:Variable .

satellite:antTtcRule rdf:type swrl:Variable .

satellite:recTtcRule rdf:type swrl:Variable .

satellite:gs rdf:type swrl:Variable .

satellite:sensor rdf:type swrl:Variable .

satellite:fprop rdf:type swrl:Variable .

satellite:control rdf:type swrl:Variable .

satellite:f1 rdf:type swrl:Variable .

satellite:actuator rdf:type swrl:Variable .

satellite:p rdf:type swrl:Variable .

satellite:c2 rdf:type swrl:Variable .

satellite:x2 rdf:type swrl:Variable .

satellite:y2 rdf:type swrl:Variable .

satellite:x4 rdf:type swrl:Variable .

satellite:y4 rdf:type swrl:Variable .

satellite:f4 rdf:type swrl:Variable .

[ rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:BuiltinAtom ;
                           swrl:builtin swrlb:lessThan ;
                           swrl:arguments [ rdf:type rdf:List ;
                                            rdf:first satellite:v ;
                                            rdf:rest [ rdf:type rdf:List ;
                                                       rdf:first "20.0"^^xsd:double ;
                                                       rdf:rest rdf:nil
                                                     ]
                                          ]
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:DatavaluedPropertyAtom ;
                                      swrl:propertyPredicate satellite:hasSignalStrength ;
                                      swrl:argument1 satellite:c ;
                                      swrl:argument2 satellite:v
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:ClassAtom ;
                                                 swrl:classPredicate satellite:Antenna ;
                                                 swrl:argument1 satellite:c
                                               ] ;
                                     rdf:rest rdf:nil
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate satellite:hasFault ;
                           swrl:argument1 satellite:c ;
                           swrl:argument2 satellite:AntennaFault_001
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

[ rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:ClassAtom ;
                           swrl:classPredicate satellite:CommandReceiver ;
                           swrl:argument1 satellite:c
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:BuiltinAtom ;
                                      swrl:builtin swrlb:lessThan ;
                                      swrl:arguments [ rdf:type rdf:List ;
                                                       rdf:first satellite:v ;
                                                       rdf:rest [ rdf:type rdf:List ;
                                                                  rdf:first "20.0"^^xsd:double ;
                                                                  rdf:rest rdf:nil
                                                                ]
                                                     ]
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:DatavaluedPropertyAtom ;
                                                 swrl:propertyPredicate satellite:hasSignalStrength ;
                                                 swrl:argument1 satellite:c ;
                                                 swrl:argument2 satellite:v
                                               ] ;
                                     rdf:rest rdf:nil
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate satellite:hasFault ;
                           swrl:argument1 satellite:c ;
                           swrl:argument2 satellite:CommandReceiverFault_001
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

[ rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:DatavaluedPropertyAtom ;
                           swrl:propertyPredicate satellite:hasTemperature ;
                           swrl:argument1 satellite:c ;
                           swrl:argument2 satellite:v
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:BuiltinAtom ;
                                      swrl:builtin swrlb:greaterThan ;
                                      swrl:arguments [ rdf:type rdf:List ;
                                                       rdf:first satellite:v ;
                                                       rdf:rest [ rdf:type rdf:List ;
                                                                  rdf:first "100.0"^^xsd:double ;
                                                                  rdf:rest rdf:nil
                                                                ]
                                                     ]
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:ClassAtom ;
                                                 swrl:classPredicate satellite:Component ;
                                                 swrl:argument1 satellite:c
                                               ] ;
                                     rdf:rest rdf:nil
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate satellite:hasFault ;
                           swrl:argument1 satellite:c ;
                           swrl:argument2 satellite:OverheatFault_001
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

[ rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:ClassAtom ;
                           swrl:classPredicate satellite:AntennaPointing ;
                           swrl:argument1 satellite:c
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:BuiltinAtom ;
                                      swrl:builtin swrlb:greaterThan ;
                                      swrl:arguments [ rdf:type rdf:List ;
                                                       rdf:first satellite:v ;
                                                       rdf:rest [ rdf:type rdf:List ;
                                                                  rdf:first "3.0"^^xsd:double ;
                                                                  rdf:rest rdf:nil
                                                                ]
                                                     ]
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:DatavaluedPropertyAtom ;
                                                 swrl:propertyPredicate satellite:hasPointingError ;
                                                 swrl:argument1 satellite:c ;
                                                 swrl:argument2 satellite:v
                                               ] ;
                                     rdf:rest rdf:nil
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate satellite:hasFault ;
                           swrl:argument1 satellite:c ;
                           swrl:argument2 satellite:AntennaPointingFault_001
                         ] ;
